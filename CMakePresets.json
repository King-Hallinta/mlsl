{
	"version": 6,
	"configurePresets": [
		{
			"name": "vs2026",
			"displayName": "Visual Studio 2026",
			"generator": "Visual Studio 18 2026",
			"architecture": "x64",
			"binaryDir": "${sourceDir}/Build/CMake/vs2026"
		},
		{
			"name": "ninja-debug",
			"displayName": "Ninja Debug",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/Build/CMake/ninja-debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "ninja-release",
			"displayName": "Ninja Release",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/Build/CMake/ninja-release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		}
	],
	"buildPresets": [
		{
			"name": "vs2026-debug",
			"configurePreset": "vs2026",
			"configuration": "Debug"
		},
		{
			"name": "vs2026-release",
			"configurePreset": "vs2026",
			"configuration": "Release"
		},
		{
			"name": "ninja-debug",
			"configurePreset": "ninja-debug"
		},
		{
			"name": "ninja-release",
			"configurePreset": "ninja-release"
		}
	]
}
